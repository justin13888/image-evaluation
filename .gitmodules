[submodule "vendor/zlib"]
	path = vendor/zlib
	url = https://github.com/madler/zlib.git
[submodule "vendor/mimalloc"]
	path = vendor/mimalloc
	url = https://github.com/microsoft/mimalloc.git
[submodule "vendor/libjpeg-turbo"]
	path = vendor/libjpeg-turbo
	url = https://github.com/libjpeg-turbo/libjpeg-turbo.git
[submodule "vendor/mozjpeg"]
	path = vendor/mozjpeg
	url = https://github.com/mozilla/mozjpeg.git
[submodule "vendor/libpng"]
	path = vendor/libpng
	url = https://github.com/pnggroup/libpng.git
[submodule "vendor/spng"]
	path = vendor/spng
	url = https://github.com/randy408/libspng.git
[submodule "vendor/libwebp"]
	path = vendor/libwebp
	url = https://chromium.googlesource.com/webm/libwebp.git
[submodule "vendor/dav1d"]
	path = vendor/dav1d
	url = https://code.videolan.org/videolan/dav1d.git
[submodule "vendor/aom"]
	path = vendor/aom
	url = https://aomedia.googlesource.com/aom.git
[submodule "vendor/libavif"]
	path = vendor/libavif
	url = https://github.com/AOMediaCodec/libavif.git
[submodule "vendor/libjxl"]
	path = vendor/libjxl
	url = https://github.com/libjxl/libjxl.git
[submodule "vendor/SVT-AV1"]
	path = vendor/SVT-AV1
	url = https://gitlab.com/AOMediaCodec/SVT-AV1.git
[submodule "vendor/libgav1"]
	path = vendor/libgav1
	url = https://chromium.googlesource.com/codecs/libgav1.git
[submodule "vendor/rav1d"]
	path = vendor/rav1d
	url = https://github.com/memorysafety/rav1d.git
[submodule "vendor/jxl-rs"]
	path = vendor/jxl-rs
	url = https://github.com/libjxl/jxl-rs.git
[submodule "vendor/codec-corpus"]
	path = vendor/codec-corpus
	url = https://github.com/imazen/codec-corpus.git
	ignore = untracked
[submodule "vendor/nasm"]
	path = vendor/nasm
	url = https://github.com/netwide-assembler/nasm.git
	# nasm is configured + built in-tree (no out-of-tree build support), so its
	# build artifacts dirty the working tree; ignore them in status/diff.
	ignore = dirty
