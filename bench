#!/usr/bin/env .venv/bin/python
"""
Image Evaluation Runner

Orchestrates compilation, execution, and result collection for image codec benchmarks.
See README.md for full methodology and usage details.
"""

import sys
import traceback

import tyro
from colorama import init

from bench_lib.models import (
    CliEntry,
    CleanArgs,
    CompileArgs,
    DocsArgs,
    ReportArgs,
    RunArgs,
    SetupArgs,
)
from bench_lib.runner import (
    run_clean,
    run_compile,
    run_docs,
    run_report,
    run_setup,
    run_sweep,
)

init(autoreset=True)

if __name__ == "__main__":
    try:
        args = tyro.cli(CliEntry)  # pyright: ignore[reportArgumentType, reportCallIssue]
        if isinstance(args, CleanArgs):
            run_clean(args)

        elif isinstance(args, CompileArgs):
            run_compile(args)

        elif isinstance(args, SetupArgs):
            run_setup(args)

        elif isinstance(args, DocsArgs):
            run_docs(args)

        elif isinstance(args, ReportArgs):
            run_report(args)

        # RunArgs and its backward-compatible aliases (quality/perf/all) are all
        # RunArgs subclasses, so this single branch handles every sweep command.
        # (ReportArgs is a plain BaseModel, handled above, so order is irrelevant.)
        elif isinstance(args, RunArgs):
            run_sweep(args)

        else:
            print("Error: Unknown command")
            sys.exit(1)
    except KeyboardInterrupt:
        print("\n\nBenchmark interrupted by user")
        sys.exit(1)
    except Exception as e:
        print(f"\nError: {e}")

        traceback.print_exc()
        sys.exit(1)

    sys.exit(0)
